# Public (browser-safe)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use either the dashboard “Publishable” key (sb_publishable_…) or the legacy JWT anon key:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: Postgres connection URI for `npm run db:migrate` (Settings → Database → Connection string)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Server-only (never use NEXT_PUBLIC_* for these). Import from `@/lib/env/server` in server code only.
# Required for post-pack image upload to Supabase Storage (service role bypasses Storage RLS).
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — text generation (e.g. gpt-4o-mini) and optional prompt transforms for images
OPENAI_API_KEY=
# Image generation defaults (provider abstraction in src/lib/generate/images/)
# IMAGE_GENERATION_PROVIDER=openai
# OPENAI_IMAGE_MODEL=gpt-image-1
